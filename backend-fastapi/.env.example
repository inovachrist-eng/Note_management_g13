# ── Base de données ──────────────────────────────────────────────
# SQLite par défaut (un simple fichier). Pour MySQL/Postgres, change l'URL :
#   mysql+pymysql://user:pass@127.0.0.1:3306/notes
#   postgresql+psycopg://user:pass@127.0.0.1:5432/notes
DATABASE_URL=sqlite:///./app.db

# ── Frontend ─────────────────────────────────────────────────────
# Utilisé pour construire l'URL du lien magique + autoriser le CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Durée de validité du lien magique (minutes)
MAGIC_LINK_TTL_MINUTES=15

# ── Envoi d'email ────────────────────────────────────────────────
# "log"  → le lien magique est affiché dans la console (pratique en dev)
# "smtp" → envoi réel via le serveur SMTP configuré ci-dessous
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=hello@example.com
MAIL_FROM_NAME=Note Management
